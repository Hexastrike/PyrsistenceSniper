<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>PyrsistenceSniper Report</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
::selection { background: #333; color: #e5e5e5; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  background-color: #000000; color: #e5e5e5; line-height: 1.5; padding: 1.5rem;
}
a { color: #d6336c; text-decoration: none; }
a:hover { text-decoration: underline; }
.report-header {
  margin-bottom: 1.5rem;
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
}
.brand { display: flex; flex-direction: column; }
.brand-name { font-size: 1.6rem; font-weight: 600; color: #e5e5e5; letter-spacing: -0.02em; }
.brand-tag { font-size: 0.85rem; color: #888888; }
.report-header .timestamp { color: #888888; font-size: 0.85rem; }
.stats-bar { display: flex; align-items: baseline; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.25rem 0; }
.stat-card {
  display: flex; align-items: baseline; gap: 0.35rem;
  padding: 0.3rem 1.1rem; background: #111111; border: 1px solid #222; border-radius: 0.4rem;
}
.stat-card:first-child { padding-left: 1.1rem; }
.stat-card .stat-label { font-size: 0.8rem; color: #888888; order: -1; }
.stat-card .stat-value { font-size: 0.95rem; font-weight: 600; }
.stat-total .stat-value { color: #e5e5e5; }
.stat-high .stat-value { color: #e8366f; }
.stat-medium .stat-value { color: #f0983e; }
.stat-low .stat-value { color: #34d399; }
.stat-info .stat-value { color: #38bdf8; }
.controls { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center; }
.controls input[type="text"] {
  background: #000000; border: 1px solid #333333; border-radius: 0.6rem;
  color: #e5e5e5; padding: 0.4rem 0.75rem; font-size: 0.85rem; min-width: 220px;
}
.controls input[type="text"]:focus { outline: none; border-color: #555; }
.controls input[type="text"]::placeholder { color: #888888; }
.filter-wrap { position: relative; }
.btn-filter {
  background: #111111; border: 1px solid #333333; border-radius: 0.6rem;
  color: #e5e5e5; padding: 0.4rem 0.75rem; font-size: 0.85rem; cursor: pointer;
  white-space: nowrap;
}
.btn-filter:hover { border-color: #888888; }
.btn-filter.active { border-color: #d6336c; }
.filter-panel {
  display: none; position: absolute; top: 100%; left: 0; margin-top: 0.35rem; z-index: 900;
  background: #111111; border: 1px solid #333333;
  border-radius: 0.6rem; box-shadow: 0 8px 24px rgba(0,0,0,0.5); padding: 0.35rem 0;
  min-width: 200px; max-height: 320px; overflow-y: auto;
}
.filter-panel.open { display: block; }
.filter-panel .filter-select-all {
  display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.75rem;
  border-bottom: 1px solid #333333; margin-bottom: 0.25rem;
  font-size: 0.8rem; font-weight: 600; color: #e5e5e5; cursor: pointer; white-space: nowrap;
}
.filter-panel .filter-select-all:hover { background: #2a2a2a; }
.filter-panel label {
  display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.75rem;
  font-size: 0.8rem; color: #e5e5e5; cursor: pointer; white-space: nowrap;
}
.filter-panel label:hover { background: #333333; }
.filter-panel input[type="checkbox"] { accent-color: #d6336c; }
.btn-reset, .btn-columns {
  background: transparent; border: 1px solid #333333; border-radius: 0.6rem;
  color: #888888; padding: 0.4rem 0.75rem; font-size: 0.85rem; cursor: pointer;
}
.btn-reset:hover, .btn-columns:hover { color: #e5e5e5; border-color: #888888; }
.col-picker-wrap { position: relative; }
.col-picker {
  display: none; position: absolute; top: 100%; left: 0; margin-top: 0.35rem; z-index: 900;
  background: #111111; border: 1px solid #333333;
  border-radius: 0.6rem; box-shadow: 0 8px 24px rgba(0,0,0,0.5); padding: 0.35rem 0;
  min-width: 180px; max-height: 320px; overflow-y: auto;
}
.col-picker.open { display: block; }
.col-picker label {
  display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.75rem;
  font-size: 0.8rem; color: #e5e5e5; cursor: pointer; white-space: nowrap;
}
.col-picker label:hover { background: #333333; }
.col-picker input[type="checkbox"] { accent-color: #d6336c; }
.row-count { color: #888888; font-size: 0.85rem; margin-left: auto; }
.table-wrapper { overflow: auto; border: 1px solid #333333; border-radius: 0.6rem; max-height: calc(100vh - 14rem); }
table { border-collapse: collapse; width: 100%; font-size: 0.8rem; table-layout: fixed; }
th {
  background: #111111; color: #e5e5e5; border-bottom: 2px solid #333333;
  padding: 0.6rem 0.75rem; text-align: left; position: sticky; top: 0; z-index: 1;
  cursor: pointer; user-select: none; white-space: nowrap;
}
th:hover { background: #2a2a2a; }
th .sort-indicator { margin-left: 0.3rem; display: inline-flex; vertical-align: middle; opacity: 0.4; }
th .sort-indicator.active { opacity: 1; }
th .col-resize {
  position: absolute; right: 0; top: 0; bottom: 0; width: 5px;
  cursor: col-resize; user-select: none;
}
th .col-resize:hover { background: #555; }
td {
  padding: 0.5rem 0.75rem; border-bottom: 1px solid #333333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
tr:nth-child(odd) td { background: #0a0a0a; }
tr:nth-child(even) td { background: #111111; }
tr:hover td { background: #1a1a1a; }
.badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.75rem; font-weight: 600; }
.badge-high { background: rgba(232,54,111,0.14); color: #e8366f; }
.badge-medium { background: rgba(240,152,62,0.14); color: #f0983e; }
.badge-low { background: rgba(52,211,153,0.14); color: #34d399; }
.badge-info { background: rgba(56,189,248,0.14); color: #38bdf8; }
#context-menu {
  display: none; position: fixed; z-index: 1000;
  background: #111111; border: 1px solid #333333;
  border-radius: 0.6rem; box-shadow: 0 8px 24px rgba(0,0,0,0.5); min-width: 200px; padding: 0.25rem 0;
}
#context-menu .ctx-item {
  display: block; width: 100%; border: none; background: none; color: #e5e5e5;
  padding: 0.5rem 0.75rem; text-align: left; font-size: 0.85rem; cursor: pointer;
}
#context-menu .ctx-item:hover { background: #333333; }
#context-menu .ctx-sep { border-top: 1px solid #333333; margin: 0.25rem 0; }
.report-footer {
  text-align: center; color: #888888; font-size: 0.8rem;
  padding: 1.5rem 0 0.5rem; border-top: 1px solid #333333; margin-top: 1.5rem;
}
</style>
</head>
<body>
<div class="report-header">
  <div class="brand">
    <span class="brand-name">PyrsistenceSniper</span>
    <span class="brand-tag">Offline Windows Persistence Detection</span>
  </div>
  <div class="timestamp" id="gen-time"></div>
</div>
<div class="stats-bar">
  <div class="stat-card stat-total"><div class="stat-value">{{ total }}</div><div class="stat-label">Total</div></div>
  <div class="stat-card stat-high"><div class="stat-value">{{ severity_counts.HIGH }}</div><div class="stat-label">High</div></div>
  <div class="stat-card stat-medium"><div class="stat-value">{{ severity_counts.MEDIUM }}</div><div class="stat-label">Medium</div></div>
  <div class="stat-card stat-low"><div class="stat-value">{{ severity_counts.LOW }}</div><div class="stat-label">Low</div></div>
  <div class="stat-card stat-info"><div class="stat-value">{{ severity_counts.INFO }}</div><div class="stat-label">Info</div></div>
</div>
<div class="controls">
  <input type="text" id="search" placeholder="Search all fields...">
  <div class="filter-wrap"><button type="button" class="btn-filter" id="btn-filter-severity">All Severities</button><div class="filter-panel" id="panel-severity"></div></div>
  <div class="filter-wrap"><button type="button" class="btn-filter" id="btn-filter-technique">All Techniques</button><div class="filter-panel" id="panel-technique"></div></div>
  <div class="filter-wrap"><button type="button" class="btn-filter" id="btn-filter-mitre">All MITRE IDs</button><div class="filter-panel" id="panel-mitre"></div></div>
  <div class="filter-wrap"><button type="button" class="btn-filter" id="btn-filter-access">All Access Levels</button><div class="filter-panel" id="panel-access"></div></div>
  <button type="button" id="reset-filters" class="btn-reset">Reset</button>
  <div class="col-picker-wrap">
    <button type="button" id="col-toggle" class="btn-columns">Columns</button>
    <div class="col-picker" id="col-picker"></div>
  </div>
  <span class="row-count" id="row-count"></span>
</div>
<div class="table-wrapper">
  <table>
    <thead><tr id="thead-row"></tr></thead>
    <tbody id="tbody"></tbody>
  </table>
</div>
<div id="context-menu">
  <button class="ctx-item" data-action="vt-search">Search on VirusTotal</button>
  <button class="ctx-item" data-action="vt-sha256" id="ctx-vt-sha256">Search SHA256 on VirusTotal</button>
  <button class="ctx-item" data-action="google">Search on Google</button>
  <div class="ctx-sep"></div>
  <button class="ctx-item" data-action="copy-value">Copy Value</button>
  <button class="ctx-item" data-action="copy-sha256" id="ctx-copy-sha256">Copy SHA256</button>
  <button class="ctx-item" data-action="copy-path">Copy Path</button>
  <button class="ctx-item" data-action="copy-json">Copy Row as JSON</button>
</div>
<div class="report-footer">
  Powered by <strong>PyrsistenceSniper</strong> &middot; Hexastrike Cybersecurity
</div>
<script>
(function(){
"use strict";
var DATA={{ results|tojson }};
var FIELDS={{ fieldnames|tojson }};
var LABELS={{ labels|tojson }};
var sortField=null,sortAsc=true,ctxRow=null;
var visibleFields=new Set(FIELDS);
var searchEl=document.getElementById("search");
var theadRow=document.getElementById("thead-row");
var tbody=document.getElementById("tbody");
var rowCountEl=document.getElementById("row-count");
var ctxMenu=document.getElementById("context-menu");
var colPicker=document.getElementById("col-picker");
var SVG_UP='<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 6.5L5 4L7.5 6.5"/></svg>';
var SVG_DN='<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 3.5L5 6L7.5 3.5"/></svg>';
var SVG_BOTH='<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 6.5L5 8L7.5 6.5M2.5 3.5L5 2L7.5 3.5"/></svg>';
var DEFAULT_WIDTHS={path:280,value:260,technique:180,mitre_id:90,description:220,access_gained:100,severity:80,is_lolbin:60,exists:60,sha256:160,is_builtin:60,is_in_os_directory:80,signer:140,hostname:100,check_id:120,references:200};

/* --- Filter state --- */
var FILTER_DEFS=[
  {key:"severity",field:"severity",allLabel:"All Severities",shortLabel:"Severities"},
  {key:"technique",field:"technique",allLabel:"All Techniques",shortLabel:"Techniques"},
  {key:"mitre",field:"mitre_id",allLabel:"All MITRE IDs",shortLabel:"MITRE IDs"},
  {key:"access",field:"access_gained",allLabel:"All Access Levels",shortLabel:"Access Levels"}
];
var filterState={};

document.getElementById("gen-time").textContent="Generated: "+new Date().toLocaleString();

/* --- Filter panels --- */
function buildFilterPanel(def){
  var vals={};
  DATA.forEach(function(r){var v=r[def.field];if(v!=null&&v!=="")vals[v]=1;});
  var sorted=Object.keys(vals).sort();
  var allSet=new Set(sorted);
  filterState[def.key]={all:allSet,selected:new Set(sorted)};
  var panel=document.getElementById("panel-"+def.key);
  panel.textContent="";
  var selectAllLabel=document.createElement("label");selectAllLabel.className="filter-select-all";
  var cbAll=document.createElement("input");cbAll.type="checkbox";cbAll.checked=true;
  selectAllLabel.appendChild(cbAll);selectAllLabel.appendChild(document.createTextNode("Select All"));
  panel.appendChild(selectAllLabel);
  var checkboxes=[];
  function syncSelectAll(){
    var sel=filterState[def.key].selected.size,total=filterState[def.key].all.size;
    cbAll.checked=sel===total;cbAll.indeterminate=sel>0&&sel<total;
  }
  sorted.forEach(function(v){
    var label=document.createElement("label");
    var cb=document.createElement("input");cb.type="checkbox";cb.checked=true;cb.setAttribute("data-val",v);
    cb.addEventListener("change",function(){
      if(cb.checked)filterState[def.key].selected.add(v);else filterState[def.key].selected.delete(v);
      syncSelectAll();updateFilterButton(def);renderTable();
    });
    label.appendChild(cb);label.appendChild(document.createTextNode(v));panel.appendChild(label);
    checkboxes.push(cb);
  });
  cbAll.addEventListener("change",function(){
    if(cbAll.checked){
      checkboxes.forEach(function(cb){cb.checked=true;filterState[def.key].selected.add(cb.getAttribute("data-val"));});
    }else{
      checkboxes.forEach(function(cb){cb.checked=false;});
      filterState[def.key].selected.clear();
    }
    cbAll.indeterminate=false;
    updateFilterButton(def);renderTable();
  });
  var btn=document.getElementById("btn-filter-"+def.key);
  btn.addEventListener("click",function(e){
    e.stopPropagation();
    var wasOpen=panel.classList.contains("open");
    closeAllPanels();
    if(!wasOpen)panel.classList.add("open");
  });
}
function updateFilterButton(def){
  var st=filterState[def.key],btn=document.getElementById("btn-filter-"+def.key);
  if(st.selected.size===st.all.size){btn.textContent=def.allLabel;btn.classList.remove("active");}
  else{btn.textContent=def.shortLabel+" ("+st.selected.size+"/"+st.all.size+")";btn.classList.add("active");}
}
function closeAllPanels(){
  document.querySelectorAll(".filter-panel.open").forEach(function(p){p.classList.remove("open");});
  colPicker.classList.remove("open");
}

/* --- Table headers with default widths --- */
function buildHeaders(){
  theadRow.textContent="";
  FIELDS.forEach(function(f){
    if(!visibleFields.has(f))return;
    var th=document.createElement("th");th.textContent=LABELS[f]||f;th.setAttribute("data-field",f);
    var dw=DEFAULT_WIDTHS[f]||120;
    th.style.width=dw+"px";th.style.minWidth="20px";
    var indicator=document.createElement("span");indicator.className="sort-indicator";
    indicator.innerHTML=sortField===f?(sortAsc?SVG_UP:SVG_DN):SVG_BOTH;
    if(sortField===f)indicator.classList.add("active");
    th.appendChild(indicator);
    th.addEventListener("click",function(){if(!resizing){sortBy(f);}});
    var handle=document.createElement("div");handle.className="col-resize";
    handle.addEventListener("mousedown",function(e){e.stopPropagation();initResize(e,th);});
    th.appendChild(handle);
    theadRow.appendChild(th);
  });
}
var resizing=false;
function initResize(e,th){
  resizing=true;
  var startX=e.pageX,startW=th.offsetWidth;
  function onMove(ev){var w=Math.max(20,startW+(ev.pageX-startX));th.style.width=w+"px";th.style.minWidth=w+"px";}
  function onUp(){document.removeEventListener("mousemove",onMove);document.removeEventListener("mouseup",onUp);window.removeEventListener("blur",onUp);setTimeout(function(){resizing=false;},0);}
  document.addEventListener("mousemove",onMove);document.addEventListener("mouseup",onUp);window.addEventListener("blur",onUp);
}

/* --- Filtering & rendering --- */
function getFilteredData(){
  var query=searchEl.value.toLowerCase();
  var out=DATA.filter(function(r){
    for(var i=0;i<FILTER_DEFS.length;i++){
      var fd=FILTER_DEFS[i],st=filterState[fd.key];
      if(st.selected.size<st.all.size&&!st.selected.has(r[fd.field]))return false;
    }
    if(query){var matched=false;FIELDS.forEach(function(f){if(String(r[f]!=null?r[f]:"").toLowerCase().indexOf(query)!==-1)matched=true;});if(!matched)return false;}
    return true;
  });
  if(sortField!==null){
    out.sort(function(a,b){
      var valA=String(a[sortField]!=null?a[sortField]:""),valB=String(b[sortField]!=null?b[sortField]:"");
      var cmp=valA.localeCompare(valB,undefined,{numeric:true,sensitivity:"base"});
      return sortAsc?cmp:-cmp;
    });
  }
  return out;
}
function renderTable(){
  var rows=getFilteredData(),frag=document.createDocumentFragment();
  rows.forEach(function(r){frag.appendChild(renderRow(r));});
  tbody.textContent="";tbody.appendChild(frag);
  rowCountEl.textContent=rows.length+" / "+DATA.length+" rows";
}
function renderRow(row){
  var tr=document.createElement("tr");
  FIELDS.forEach(function(f){
    if(!visibleFields.has(f))return;
    var td=document.createElement("td");
    td.title=String(row[f]!=null?row[f]:"");
    if(f==="severity"){
      var badge=document.createElement("span");
      badge.className="badge badge-"+String(row[f]||"").toLowerCase();
      badge.textContent=row[f]||"";td.appendChild(badge);
    }else{td.textContent=row[f]!=null?String(row[f]):"";}
    tr.appendChild(td);
  });
  tr.addEventListener("contextmenu",function(e){showContextMenu(e,row);});
  return tr;
}
function sortBy(field){
  if(sortField===field){sortAsc=!sortAsc;}else{sortField=field;sortAsc=true;}
  updateSortIndicators();renderTable();
}
function updateSortIndicators(){
  theadRow.querySelectorAll("th").forEach(function(th){
    var f=th.getAttribute("data-field"),ind=th.querySelector(".sort-indicator");
    if(f===sortField){ind.innerHTML=sortAsc?SVG_UP:SVG_DN;ind.classList.add("active");}
    else{ind.innerHTML=SVG_BOTH;ind.classList.remove("active");}
  });
}

/* --- Context menu --- */
function showContextMenu(e,row){
  e.preventDefault();ctxRow=row;
  var sha=row.sha256||"";
  document.getElementById("ctx-vt-sha256").style.display=sha?"":"none";
  document.getElementById("ctx-copy-sha256").style.display=sha?"":"none";
  ctxMenu.style.display="block";
  var x=e.clientX,y=e.clientY,menuW=ctxMenu.offsetWidth,menuH=ctxMenu.offsetHeight;
  if(x+menuW>window.innerWidth)x=window.innerWidth-menuW-5;
  if(y+menuH>window.innerHeight)y=window.innerHeight-menuH-5;
  ctxMenu.style.left=x+"px";ctxMenu.style.top=y+"px";
}
function hideContextMenu(){ctxMenu.style.display="none";ctxRow=null;}
function handleContextAction(action){
  if(!ctxRow)return;
  var selection=window.getSelection().toString().trim();
  var term=selection||(ctxRow.value||"");
  switch(action){
    case"vt-search":window.open("https://www.virustotal.com/gui/search/"+encodeURIComponent(term));break;
    case"vt-sha256":window.open("https://www.virustotal.com/gui/file/"+encodeURIComponent(ctxRow.sha256||""));break;
    case"google":window.open("https://www.google.com/search?q="+encodeURIComponent(term));break;
    case"copy-value":navigator.clipboard.writeText(ctxRow.value||"");break;
    case"copy-sha256":navigator.clipboard.writeText(ctxRow.sha256||"");break;
    case"copy-path":navigator.clipboard.writeText(ctxRow.path||"");break;
    case"copy-json":navigator.clipboard.writeText(JSON.stringify(ctxRow,null,2));break;
  }
  hideContextMenu();
}

/* --- Event listeners --- */
var debounceTimer;searchEl.addEventListener("input",function(){clearTimeout(debounceTimer);debounceTimer=setTimeout(renderTable,200);});
document.getElementById("reset-filters").addEventListener("click",function(){
  searchEl.value="";sortField=null;sortAsc=true;visibleFields=new Set(FIELDS);
  FILTER_DEFS.forEach(function(def){
    var st=filterState[def.key];
    st.selected=new Set(st.all);
    document.getElementById("panel-"+def.key).querySelectorAll('input[type="checkbox"]').forEach(function(cb){cb.checked=true;});
    updateFilterButton(def);
  });
  buildColPicker();buildHeaders();renderTable();
});
document.addEventListener("click",function(e){
  hideContextMenu();
  if(!e.target.closest(".filter-wrap")&&!e.target.closest(".col-picker-wrap"))closeAllPanels();
});
document.addEventListener("scroll",hideContextMenu,true);
document.addEventListener("keydown",function(e){if(e.key==="Escape"){hideContextMenu();closeAllPanels();}});
ctxMenu.querySelectorAll(".ctx-item").forEach(function(btn){
  btn.addEventListener("click",function(e){e.stopPropagation();handleContextAction(btn.getAttribute("data-action"));});
});
function buildColPicker(){
  colPicker.textContent="";
  FIELDS.forEach(function(f){
    var label=document.createElement("label");
    var checkbox=document.createElement("input");checkbox.type="checkbox";checkbox.checked=visibleFields.has(f);
    checkbox.addEventListener("change",function(){
      if(checkbox.checked)visibleFields.add(f);else visibleFields.delete(f);
      buildHeaders();renderTable();
    });
    label.appendChild(checkbox);label.appendChild(document.createTextNode(LABELS[f]||f));colPicker.appendChild(label);
  });
}
document.getElementById("col-toggle").addEventListener("click",function(e){
  e.stopPropagation();
  var wasOpen=colPicker.classList.contains("open");
  closeAllPanels();
  if(!wasOpen)colPicker.classList.add("open");
});

/* --- Init --- */
buildColPicker();buildHeaders();FILTER_DEFS.forEach(buildFilterPanel);renderTable();
})();
</script>
</body>
</html>
